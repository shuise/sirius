{
  "manifest_version": 3,
  "name": "Sirius",
  "version": "0.1.0",
  "description": "Lift up readability and accessibility via content scripts.",
  "permissions": [
    "storage",
    "debugger",
    "activeTab"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Sirius"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
